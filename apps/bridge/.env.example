SURF_AI_HOST=127.0.0.1
SURF_AI_PORT=43127
SURF_AI_DB_PATH=./data/surf-ai.sqlite
SURF_AI_TOKEN=
SURF_AI_DEFAULT_USER_ID=local
SURF_AI_DEFAULT_USER_NAME=Local User
# Multi-user mode example:
# SURF_AI_USERS_JSON=[{"id":"u1","name":"Alice","token":"alice-token"},{"id":"u2","name":"Bob","token":"bob-token"}]
SURF_AI_DEFAULT_ADAPTER=mock

# Security / Production hardening
SURF_AI_CORS_ALLOW_ORIGINS=chrome-extension://*,http://localhost:*,https://localhost:*,http://127.0.0.1:*,https://127.0.0.1:*
SURF_AI_REQUIRE_HTTPS=0
SURF_AI_TRUST_PROXY=0
SURF_AI_RATE_LIMIT_ENABLED=1
SURF_AI_RATE_LIMIT_WINDOW_MS=60000
SURF_AI_RATE_LIMIT_MAX_REQUESTS=120
SURF_AI_RETENTION_ENABLED=1
SURF_AI_RETENTION_SESSION_DAYS=90
SURF_AI_RETENTION_AUDIT_DAYS=30

# MiniMax TTS
SURF_AI_MINIMAX_API_KEY=
SURF_AI_MINIMAX_TTS_ENDPOINT=https://api.minimax.io/v1/t2a_v2
SURF_AI_MINIMAX_TTS_MODEL=speech-02-hd
SURF_AI_MINIMAX_TTS_VOICE_ID=male-qn-qingse
SURF_AI_MINIMAX_TTS_OUTPUT_FORMAT=hex
SURF_AI_MINIMAX_TTS_AUDIO_FORMAT=mp3
SURF_AI_MINIMAX_TTS_SAMPLE_RATE=32000
SURF_AI_MINIMAX_TTS_BITRATE=128000
SURF_AI_MINIMAX_TTS_CHANNEL=1
SURF_AI_MINIMAX_TTS_SPEED=1
SURF_AI_MINIMAX_TTS_VOLUME=1
SURF_AI_MINIMAX_TTS_PITCH=0
SURF_AI_MINIMAX_TTS_TIMEOUT_MS=30000
