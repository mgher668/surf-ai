{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/hangtag-template.schema.json",
  "title": "Hangtag Template Schema",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "templateVersion",
    "designAppVersion",
    "meta",
    "resources",
    "dataBindings",
    "canvas"
  ],
  "properties": {
    "$schema": {
      "type": "string",
      "format": "uri"
    },
    "templateVersion": {
      "type": "string",
      "pattern": "^v\\d+(?:\\.\\d+)?$"
    },
    "designAppVersion": {
      "type": "string"
    },
    "meta": {
      "$ref": "#/$defs/meta"
    },
    "resources": {
      "$ref": "#/$defs/resources"
    },
    "dataBindings": {
      "$ref": "#/$defs/dataBindings"
    },
    "canvas": {
      "$ref": "#/$defs/canvas"
    }
  },
  "$defs": {
    "meta": {
      "type": "object",
      "required": [
        "templateId",
        "displayName",
        "page"
      ],
      "additionalProperties": false,
      "properties": {
        "templateId": {
          "type": "string",
          "minLength": 1
        },
        "displayName": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string"
        },
        "page": {
          "type": "object",
          "required": [
            "size",
            "widthPt",
            "heightPt"
          ],
          "additionalProperties": false,
          "properties": {
            "size": {
              "type": "string",
              "enum": ["A4", "A5", "Letter", "Legal", "Custom"]
            },
            "widthPt": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "heightPt": {
              "type": "number",
              "exclusiveMinimum": 0
            },
            "bleedPt": {
              "type": "number",
              "minimum": 0
            }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "required": ["fonts", "images"],
      "properties": {
        "fonts": {
          "type": "array",
          "items": { "$ref": "#/$defs/fontResource" },
          "default": []
        },
        "images": {
          "type": "array",
          "items": { "$ref": "#/$defs/imageResource" },
          "default": []
        }
      }
    },
    "fontResource": {
      "type": "object",
      "required": ["id", "family", "weight", "uri"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "family": { "type": "string" },
        "weight": { "type": "integer", "minimum": 100, "maximum": 900 },
        "style": { "type": "string", "enum": ["normal", "italic", "oblique"] },
        "subset": { "type": "string" },
        "uri": { "type": "string", "format": "uri" },
        "embed": { "type": "boolean", "default": true }
      }
    },
    "imageResource": {
      "type": "object",
      "required": ["id", "uri"],
      "additionalProperties": false,
      "properties": {
        "id": { "type": "string" },
        "uri": { "type": "string", "format": "uri" },
        "checksum": { "type": "string" },
        "type": { "type": "string", "enum": ["svg", "png", "jpeg", "webp"] },
        "widthPx": { "type": "number", "minimum": 0 },
        "heightPx": { "type": "number", "minimum": 0 }
      }
    },
    "dataBindings": {
      "type": "object",
      "additionalProperties": false,
      "required": ["requiredFields"],
      "properties": {
        "requiredFields": {
          "type": "array",
          "items": { "type": "string" },
          "uniqueItems": true
        },
        "samplePayload": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "canvas": {
      "type": "object",
      "additionalProperties": true,
      "required": ["objects", "version"],
      "properties": {
        "type": { "const": "fabric-canvas" },
        "version": { "type": "string" },
        "width": { "type": "number", "minimum": 0 },
        "height": { "type": "number", "minimum": 0 },
        "background": { "type": "string" },
        "backgroundImage": { "type": ["object", "null"] },
        "overlayImage": { "type": ["object", "null"] },
        "clipPath": { "type": ["object", "null"] },
        "objects": {
          "type": "array",
          "items": { "$ref": "#/$defs/fabricObject" }
        }
      }
    },
    "fabricObject": {
      "anyOf": [
        { "$ref": "#/$defs/textObject" },
        { "$ref": "#/$defs/imageObject" },
        { "$ref": "#/$defs/pathObject" },
        { "$ref": "#/$defs/lineObject" },
        { "$ref": "#/$defs/ellipseObject" },
        { "$ref": "#/$defs/polygonObject" },
        { "$ref": "#/$defs/groupObject" },
        { "$ref": "#/$defs/symbologyPlaceholder" },
        { "$ref": "#/$defs/rectObject" }
      ]
    },
    "baseObject": {
      "type": "object",
      "properties": {
        "type": { "type": "string" },
        "componentType": { "type": "string" },
        "originX": { "type": "string", "enum": ["left", "center", "right"] },
        "originY": { "type": "string", "enum": ["top", "center", "bottom"] },
        "left": { "type": "number" },
        "top": { "type": "number" },
        "width": { "type": "number" },
        "height": { "type": "number" },
        "angle": { "type": "number" },
        "opacity": { "type": "number", "minimum": 0, "maximum": 1 },
        "scaleX": { "type": "number" },
        "scaleY": { "type": "number" },
        "flipX": { "type": "boolean" },
        "flipY": { "type": "boolean" },
        "skewX": { "type": "number" },
        "skewY": { "type": "number" },
        "stroke": { "type": ["string", "null"] },
        "strokeWidth": { "type": "number", "minimum": 0 },
        "strokeDashArray": {
          "type": "array",
          "items": { "type": "number", "minimum": 0 }
        },
        "fill": { "type": ["string", "null"] },
        "shadow": { "$ref": "#/$defs/shadow" },
        "clipPath": { "type": ["object", "null"] },
        "dataBinding": { "$ref": "#/$defs/dataBinding" },
        "renderHints": { "$ref": "#/$defs/renderHints" },
        "resourceRef": { "type": "string" },
        "zIndex": { "type": "integer" },
        "customMetadata": { "type": "object" }
      }
    },
    "shadow": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "properties": {
        "color": { "type": "string" },
        "blur": { "type": "number", "minimum": 0 },
        "offsetX": { "type": "number" },
        "offsetY": { "type": "number" }
      }
    },
    "renderHints": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pdfReuse": { "type": "boolean" },
        "pictureCache": { "type": "boolean" },
        "antialias": { "type": "boolean" },
        "flattenToPath": { "type": "boolean" },
        "autoScale": { "type": "boolean" },
        "preferVector": { "type": "boolean" },
        "quietZoneModules": { "type": ["number", "null"] },
        "errorCorrection": { "type": "string", "enum": ["L", "M", "Q", "H"] },
        "moduleWidthOverride": { "type": ["number", "null"], "minimum": 0 }
      }
    },
    "dataBinding": {
      "type": ["object", "null"],
      "additionalProperties": false,
      "required": ["field"],
      "properties": {
        "field": { "type": "string", "minLength": 1 },
        "format": { "type": "string" },
        "fallback": { "type": ["string", "number", "null"] }
      }
    },
    "textObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "text", "fontSize", "fontFamily"],
          "properties": {
            "type": { "enum": ["text", "textbox", "i-text"] },
            "componentType": { "const": "textBlock" },
            "text": { "type": "string" },
            "fontSize": { "type": "number", "minimum": 1 },
            "fontFamily": { "type": "string" },
            "fontWeight": { "type": ["integer", "string"] },
            "fontStyle": { "type": "string", "enum": ["normal", "italic", "oblique"] },
            "underline": { "type": "boolean" },
            "linethrough": { "type": "boolean" },
            "overline": { "type": "boolean" },
            "textAlign": { "type": "string", "enum": ["left", "center", "right", "justify"] },
            "lineHeight": { "type": "number", "minimum": 0.5 },
            "charSpacing": { "type": "number" },
            "renderConstraints": {
              "type": "object",
              "additionalProperties": false,
              "properties": {
                "maxLines": { "type": "integer", "minimum": 1 },
                "overflow": { "type": "string", "enum": ["clip", "ellipsis", "shrinkToFit"] },
                "autoScale": { "type": "boolean" }
              }
            }
          }
        }
      ]
    },
    "imageObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "resourceRef"],
          "properties": {
            "type": { "const": "image" },
            "componentType": { "const": "imageBlock" },
            "cropX": { "type": "number" },
            "cropY": { "type": "number" },
            "objectCaching": { "type": "boolean" },
            "filterStack": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["name"],
                "properties": {
                  "name": { "type": "string" },
                  "options": { "type": "object" }
                }
              }
            }
          }
        }
      ]
    },
    "pathObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "path"],
          "properties": {
            "type": { "enum": ["path", "polygon"] },
            "componentType": { "const": "vectorShape" },
            "path": { "type": ["string", "array"] },
            "points": {
              "type": "array",
              "items": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              }
            },
            "strokeLineCap": { "type": "string", "enum": ["butt", "round", "square"] },
            "strokeLineJoin": { "type": "string", "enum": ["miter", "round", "bevel"] },
            "strokeMiterLimit": { "type": "number", "minimum": 1 }
          }
        }
      ]
    },
    "lineObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "x1", "y1", "x2", "y2"],
          "properties": {
            "type": { "const": "line" },
            "componentType": { "const": "decor" },
            "x1": { "type": "number" },
            "y1": { "type": "number" },
            "x2": { "type": "number" },
            "y2": { "type": "number" }
          }
        }
      ]
    },
    "ellipseObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "rx", "ry"],
          "properties": {
            "type": { "const": "ellipse" },
            "componentType": { "const": "decor" },
            "rx": { "type": "number", "minimum": 0 },
            "ry": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "polygonObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "componentType", "points"],
          "properties": {
            "type": { "const": "polygon" },
            "componentType": { "const": "vectorShape" },
            "points": {
              "type": "array",
              "minItems": 3,
              "items": {
                "type": "array",
                "items": { "type": "number" },
                "minItems": 2,
                "maxItems": 2
              }
            }
          }
        }
      ]
    },
    "rectObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type"],
          "properties": {
            "type": { "const": "rect" },
            "rx": { "type": "number", "minimum": 0 },
            "ry": { "type": "number", "minimum": 0 }
          }
        }
      ]
    },
    "groupObject": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["type", "objects"],
          "properties": {
            "type": { "const": "group" },
            "componentType": { "const": "compound" },
            "objects": {
              "type": "array",
              "items": { "$ref": "#/$defs/fabricObject" }
            }
          }
        }
      ]
    },
    "symbologyPlaceholder": {
      "allOf": [
        { "$ref": "#/$defs/baseObject" },
        {
          "type": "object",
          "required": ["componentType", "symbologyType", "dataBinding"],
          "properties": {
            "type": { "const": "rect" },
            "componentType": { "const": "symbology" },
            "symbologyType": {
              "type": "string",
              "description": "码制类型，支持所有 1D/2D 条码",
              "enum": [
                "CODE128", "CODE39", "CODE93", "CODABAR",
                "ITF", "ITF14", "MSI", "MSI10", "MSI11", "MSI1010", "MSI1110",
                "GS1_128", "EAN13", "EAN8", "UPC_A", "UPC_E",
                "GS1_DATABAR_OMNI", "GS1_DATABAR_STACKED", "GS1_DATABAR_EXPANDED",
                "PHARMACODE", "POSTNET", "PLANET", "JAPAN_POST",
                "QR", "MICRO_QR", "DATAMATRIX", "PDF417", "AZTEC", "MAXICODE"
              ]
            },
            "symbologyPresetId": {
              "type": "string",
              "description": "可选的预设 ID，用于快速应用推荐参数"
            },
            "renderHints": {
              "allOf": [
                { "$ref": "#/$defs/renderHints" }
              ]
            }
          }
        }
      ]
    }
  }
}
